---
layout: layouts/base.njk
# The home page gets the warm "first impression" music.
musicMood: welcome
---
<section class="hero">
  <h1>Welcome to the study.</h1>
  <p>{{ site.description }}</p>
  <p><a class="button" href="{{ '/puzzles/' | url }}">Browse the archive</a></p>
</section>

<section class="latest">
  <h2 class="section-title">Fresh off the desk</h2>
  {% set total = collections.puzzles.length %}
  <ol class="puzzle-list">
    {% for p in collections.puzzles | limit(3) %}
    <li class="puzzle-card">
      <span class="issue-no">Nº {{ total - loop.index0 }}</span>
      <h3><a href="{{ p.url | url }}">{{ p.data.title }}</a></h3>
      <p class="puzzle-meta">{{ p.date | readableDate }}{% if p.data.difficulty %} · {{ p.data.difficulty }}{% endif %}</p>
      {% if p.data.teaser %}<p>{{ p.data.teaser }}</p>{% endif %}
    </li>
    {% endfor %}
  </ol>
</section>
