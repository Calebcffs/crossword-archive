---
layout: layouts/base.njk
title: Puzzle Archive
permalink: /puzzles/index.html
---
<h1>The Archive</h1>
<p>{{ collections.puzzles.length }} puzzle{% if collections.puzzles.length != 1 %}s{% endif %}, newest first. Take one down off the shelf.</p>

{% set total = collections.puzzles.length %}
<ol class="puzzle-list">
  {% for p in collections.puzzles %}
  <li class="puzzle-card">
    {% if p.data.thumbnail %}
    <img class="puzzle-thumb" src="{{ (p.url + p.data.thumbnail) | url }}" alt="Preview of the grid for {{ p.data.title }}">
    {% endif %}
    <span class="issue-no">Nº {{ total - loop.index0 }}</span>
    <h2><a href="{{ p.url | url }}">{{ p.data.title }}</a></h2>
    <p class="puzzle-meta">
      {{ p.date | readableDate }}
      {%- if p.data.difficulty %} · {{ p.data.difficulty }}{% endif %}
      {%- set topics = p.data.tags | topicTags %}
      {%- if topics.length %} · {% for t in topics %}<span class="tag">{{ t }}</span>{% if not loop.last %} {% endif %}{% endfor %}{% endif %}
    </p>
    {% if p.data.teaser %}<p>{{ p.data.teaser }}</p>{% endif %}
  </li>
  {% endfor %}
</ol>
